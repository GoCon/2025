---
import Layout from "../layouts/Layout.astro";
---

<style>
  .container {
    display: flex;
    max-width: 100%;
    height: 40em;

    align-items: center;
    justify-content: center;
  }

  .card {
    padding: 8px 16px;

    background-color: #e6e6e6;
    border-radius: 4px;
  }
</style>

<Layout title="Go Conference 2025">
  <main>
    <h1>Go Conference 2025</h1>
    <div style="display: flex; flex-wrap: wrap;">
      <span>Go Conference 2025 の公式ページになります</span>
      <span></span>
    </div>
    <div style="display: flex; flex-wrap: wrap;">
      <span>本ページは随時更新予定なのでご了承ください</span>
    </div>
    <div style="display: flex; flex-wrap: wrap;"></div>
    <div class="container">
      <div>
        <div class="card">
          <h3 style="margin: 0; padding: 8px;">
            現段階(2025年5月12日)での情報になります
          </h3>
          <ul>
            <li>
              <span style="font-weight: bold">開催日時：</span>
              <ul>
                <li>
                  2025年 9月xx日(◯) 〜 9月yy日(△)
                  <ul>
                    <li>
                      <span style="display: inline-block; width: 120px;"
                        >Day1:</span
                      > 9月xx日(◯)
                    </li>
                    <li>
                      <span style="display: inline-block; width: 120px;"
                        >Day2:</span
                      > 9月yy日(△)
                    </li>
                  </ul>
                </li>
              </ul>
            </li>
            <li>
              <span style="font-weight: bold">会場：</span>
              <ul>
                <li>TODO</li>
              </ul>
            </li>
            <li>
              <span style="font-weight: bold">Day1 募集：</span>
              <ul>
                <li>
                  <a
                    href="https://gocon.jp/2025/"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    応募はこちら
                    <img
                      src="https://gocon.jp/2025/ic_external_link.svg"
                      alt="外部リンク"
                      style="width: 12px; height: 12px; margin-left: 2px;"
                    />
                  </a>
                </li>
                <li>締切: 2025年xx月yy日(◯) 23:59:59</li>
              </ul>
            </li>
            <li>
              <span style="font-weight: bold">Day2 募集：</span>
              <ul>
                <li>
                  <a
                    href="https://gocon.jp/2025/"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    応募はこちら
                    <img
                      src="https://gocon.jp/2025/ic_external_link.svg"
                      alt="外部リンク"
                      style="width: 12px; height: 12px; margin-left: 2px;"
                    />
                  </a>
                </li>
                <li>締切: 2025年xx月yy日(◯) 23:59:59</li>
              </ul>
            </li>
            <li>
              <span style="font-weight: bold">スポンサー募集：</span>
              <ul>
                <li>
                  <a
                    href="https://gocon.jp/2025"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    応募はこちら
                    <img
                      src="https://gocon.jp/2025/ic_external_link.svg"
                      alt="外部リンク"
                      style="width: 12px; height: 12px; margin-left: 2px;"
                    />
                  </a>
                </li>
                <li>締切: 2025年xx月yy日(◯) 23:59:59</li>
                <li>スポンサー抽選会: 2025年xx月yy日(◯) zz時から予定</li>
              </ul>
            </li>
            <li>
              <span style="font-weight: bold">FAQ：</span>
              <ul>
                <li>
                  <a
                    href="https://gocon.jp/2025"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    よくある質問
                    <img
                      src="https://gocon.jp/2025/ic_external_link.svg"
                      alt="外部リンク"
                      style="width: 12px; height: 12px; margin-left: 2px;"
                    />
                  </a>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</Layout>
